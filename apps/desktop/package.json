{
  "name": "skill-port-desktop",
  "productName": "Skill Port",
  "version": "0.1.2",
  "description": "Local GUI for managing Agent Skills with Skill Port",
  "author": "kanelogger",
  "private": true,
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "electron-forge package && playwright test"
  },
  "dependencies": {
    "electron-squirrel-startup": "1.0.1",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "zod": "4.0.17"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-deb": "7.11.2",
    "@electron-forge/maker-dmg": "7.11.2",
    "@electron-forge/maker-rpm": "7.11.2",
    "@electron-forge/maker-squirrel": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/plugin-fuses": "7.11.2",
    "@electron-forge/plugin-vite": "7.11.2",
    "@electron/fuses": "1.8.0",
    "@playwright/test": "1.61.1",
    "@types/react": "19.1.9",
    "@types/react-dom": "19.1.7",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "43.2.0",
    "typescript": "5.9.2",
    "vite": "7.0.6",
    "vitest": "3.2.4"
  }
